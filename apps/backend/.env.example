NODE_ENV=development
PORT=3001

# Required — use docker compose (see root POSTGRES.md) or Railway Postgres
DATABASE_URL=postgresql://clipforge:clipforge@127.0.0.1:5432/clipforge

# CORS_ORIGIN=http://localhost:3000,https://your-app.vercel.app

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1

LOCAL_UPLOAD_DIR=uploads

# S3 optional — see previous docs
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=

# Stripe optional
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_EXPORT_CREDITS=
